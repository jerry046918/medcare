# Dependencies
node_modules/
client/node_modules/
server/node_modules/

# Build artifacts (we build inside Docker)
client/build/

# Database files (use volume instead)
server/database/*.sqlite
server/database/*.sqlite-journal
server/database/*.sqlite-wal

# Uploaded files (use volume instead)
server/uploads/

# Environment files
.env
.env.local
.env.production
server/.env

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Docker (prevent recursive copy)
Dockerfile
docker-compose*.yml
.dockerignore

# Documentation
*.md
!README.md

# Test files
**/*.test.js
**/*.spec.js
coverage/

# Logs
logs/
*.log
npm-debug.log*

# Temporary files
tmp/
temp/
*.tmp
